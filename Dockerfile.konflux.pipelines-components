FROM registry.redhat.io/ubi9/python-311@sha256:a81d59327f23c1ec416c0dd95ec27b978825379eafe22666601f96a0da3279ae AS builder

USER root

ENV WHEEL_DIR=/wheelsdir/
ENV PATH="/opt/app-root/src/.cargo/bin:${PATH}"

RUN curl -LsSf https://astral.sh/uv/0.6.0/install.sh -o /tmp/uv-install.sh && \
    echo "5464b06094b6363861b99cd60a010892e52fc2a7503b7594419828e74afecfe6  /tmp/uv-install.sh" | sha256sum -c - && \
    sh /tmp/uv-install.sh && rm /tmp/uv-install.sh
RUN dnf install -y cmake ninja-build  \
    && dnf clean all \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && mkdir -p ${WHEEL_DIR} \
    && touch /tmp/ctrl

COPY pyproject.toml __init__.py uv.lock ./
COPY components/ components/
COPY pipelines/ pipelines/
COPY scripts/ scripts/
COPY utils/ utils/

RUN --mount=type=cache,target=/opt/app-root/src/.cache/uv \
    if [ "$(uname -m)" = "ppc64le" ]; then \
    PYARROW_VERSION=$(grep -A1 -E '"pyarrow"$' uv.lock | grep -Eo "[0-9\.]+") && \
    git clone --recursive https://github.com/apache/arrow.git -b apache-arrow-${PYARROW_VERSION} && \
    cd arrow/cpp && \
    mkdir build && cd build && \
    cmake -DCMAKE_BUILD_TYPE=release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DARROW_PYTHON=ON \
        -DARROW_BUILD_TESTS=OFF \
        -DARROW_JEMALLOC=ON \
        -DARROW_BUILD_STATIC="OFF" \
        -DARROW_PARQUET=ON \
        .. && \
    make install -j ${MAX_JOBS:-$(nproc)} && \
    cd ../../python/ && \
    uv pip install -v -r requirements-wheel-build.txt && \
    PYARROW_PARALLEL=${PYARROW_PARALLEL:-$(nproc)} \
    python setup.py build_ext \
        --build-type=release --bundle-arrow-cpp \
        bdist_wheel --dist-dir ${WHEEL_DIR}; \
    fi

RUN --mount=type=cache,target=/opt/app-root/src/.cache/uv \
    if [ "$(uname -m)" = "ppc64le" ]; then uv pip install ${WHEEL_DIR}/*.whl; fi && \
    uv pip install .[test] --verbose


FROM registry.redhat.io/ubi9/python-311@sha256:a81d59327f23c1ec416c0dd95ec27b978825379eafe22666601f96a0da3279ae

WORKDIR /app

USER root
RUN curl -LsSf https://astral.sh/uv/0.6.0/install.sh -o /tmp/uv-install.sh && \
    echo "5464b06094b6363861b99cd60a010892e52fc2a7503b7594419828e74afecfe6  /tmp/uv-install.sh" | sha256sum -c - && \
    sh /tmp/uv-install.sh && rm /tmp/uv-install.sh

COPY pyproject.toml __init__.py uv.lock ./
COPY components/ components/
COPY pipelines/ pipelines/
COPY scripts/ scripts/
COPY utils/ utils/

# wait for builder stage
COPY --from=builder /tmp/ctrl /dev/null
RUN --mount=type=cache,target=/opt/app-root/src/.cache/uv \
    --mount=type=cache,from=builder,source=/wheelsdir/,target=/wheelsdir/ \
    if [ "$(uname -m)" = "ppc64le" ]; then uv pip install /wheelsdir/*.whl; fi && \
    uv pip install .[test]

RUN mkdir -p /config && \
    chown -R 1001:1001 /app && \
    chown -R 1001:1001 /config && \
    chown -R 1001:1001 /opt/app-root/src
USER 1001

RUN uv run python -m scripts.generate_managed_pipelines.generate_managed_pipelines

CMD [".venv/bin/python", "-m", "scripts.init_managed_pipelines.init_managed_pipelines"]

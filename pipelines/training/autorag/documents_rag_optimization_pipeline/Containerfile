# This container is used to run the AutoRAG components of the training pipeline.

ARG BASE_IMAGE="quay.io/aipcc/base-images/cpu:3.4"

FROM ${BASE_IMAGE}

# Build context is this directory (see .tekton/odh-autorag-ci-*.yaml path-context).
COPY requirements.txt requirements-pypi.txt requirements-pypi-whl.txt /tmp/
COPY seed_docling_models.py artifacts.lock.yaml install_sqlite_from_source.sh /tmp/

# Build SQLite from sqlite-autoconf (Hermeto generic prefetch or download); replace system libsqlite3.
# https://github.com/hermetoproject/hermeto/blob/main/docs/generic.md
ARG HERMETO_GENERIC_DEPS=/cachi2/output/deps/generic

USER root
RUN HERMETO_GENERIC_DEPS="${HERMETO_GENERIC_DEPS}" bash /tmp/install_sqlite_from_source.sh
USER default

## TODO: Ensure build isolation
RUN pip install --index-url https://console.redhat.com/api/pypi/public-rhai/rhoai/3.4/cpu-ubi9/simple --no-cache-dir -r /tmp/requirements.txt
RUN pip install --index-url https://pypi.org/simple --no-cache-dir -r /tmp/requirements-pypi.txt
RUN pip install --index-url https://pypi.org/simple --no-cache-dir -r /tmp/requirements-pypi-whl.txt

# Docling models (Red Hat application/x-mlmodel OCI artifacts).
# These are not container images — do not use RUN --mount=from=...; prefetch blobs via Hermeto
# (artifacts.lock.yaml registry v2 blob URLs) and copy from ${HERMETO_GENERIC_DEPS} at build time.
# Konflux: hermetic + generic prefetch; link a registry.stage.redhat.io pull secret to the build SA.
ENV DOCLING_ARTIFACTS_PATH=/tmp/docling-artifacts/models
USER root
RUN mkdir -p /tmp/docling-artifacts "${DOCLING_ARTIFACTS_PATH}" \
    && if [ -d "${HERMETO_GENERIC_DEPS}" ] \
        && find "${HERMETO_GENERIC_DEPS}" -path '*/docling-project--docling-layout-heron/config.json' -print -quit | grep -q .; then \
      python3 /tmp/seed_docling_models.py --dest "${DOCLING_ARTIFACTS_PATH}" --hermeto-dir "${HERMETO_GENERIC_DEPS}"; \
    elif [ ! -f "${DOCLING_ARTIFACTS_PATH}/docling-project--docling-layout-heron/config.json" ]; then \
      python3 /tmp/seed_docling_models.py --dest "${DOCLING_ARTIFACTS_PATH}" --download; \
    fi \
    && test -f "${DOCLING_ARTIFACTS_PATH}/docling-project--docling-layout-heron/config.json" \
    && chown -R 1001:0 /tmp/docling-artifacts
USER default

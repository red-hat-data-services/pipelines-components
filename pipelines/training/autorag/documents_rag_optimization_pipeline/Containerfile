# This container is used to run the AutoRAG components of the training pipeline.

ARG DOCLING_LAYOUT_MODELCAR="registry.redhat.io/rhai/modelcar-docling-project-docling-layout-heron:3.0@sha256:fec51abe62b2a2db2e2998eaf7300d076c825f81817f4296977622fe15d7edbe"
ARG DOCLING_MODELS_MODELCAR="registry.redhat.io/rhai/modelcar-docling-project-docling-models@sha256:34ee3b291a320144b50ed7b29f04251e1179d70024de578dc2583111931a7db6"
ARG BASE_IMAGE="quay.io/aipcc/base-images/cpu:3.5.0"

FROM ${DOCLING_LAYOUT_MODELCAR} AS docling-layout-modelcar
FROM ${DOCLING_MODELS_MODELCAR} AS docling-models-modelcar
FROM ${BASE_IMAGE}

COPY pipelines/training/autorag/documents_rag_optimization_pipeline/requirements.txt \
     pipelines/training/autorag/documents_rag_optimization_pipeline/requirements-pypi.txt \
     pipelines/training/autorag/documents_rag_optimization_pipeline/requirements-pypi-whl.txt \
     /tmp/

## TODO: Ensure build isolation
RUN pip install --index-url https://console.redhat.com/api/pypi/public-rhai/rhoai/3.5/cpu-ubi9/simple --no-cache-dir -r /tmp/requirements.txt
RUN pip install --index-url https://pypi.org/simple --no-cache-dir -r /tmp/requirements-pypi.txt
RUN pip install --index-url https://pypi.org/simple --no-cache-dir -r /tmp/requirements-pypi-whl.txt

# Docling models for offline text extraction (RHAI modelcar images; /models/ -> docling-project--* layout).
# Must match DOCLING_ARTIFACTS_PATH. Do not use /opt/docling-artifacts on aipcc: non-root RUN cannot mkdir there.
ENV DOCLING_ARTIFACTS_PATH=/opt/app-root/docling-artifacts/models
USER root
RUN mkdir -p /opt/app-root/docling-artifacts/models
COPY --from=docling-layout-modelcar \
     /models/ \
     /opt/app-root/docling-artifacts/models/docling-project--docling-layout-heron/
COPY --from=docling-models-modelcar \
     /models/ \
     /opt/app-root/docling-artifacts/models/docling-project--docling-models/
RUN chown -R 1001:0 /opt/app-root/docling-artifacts
USER default
